<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<BorderPane
        style="-fx-background-color: #fdf6f0;"
        xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="PlanetMel.controller.LoginController">

    <center>
        <VBox alignment="CENTER" spacing="18.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>

            <VBox alignment="CENTER" spacing="6.0" maxWidth="480.0">
                <Label text="✦"
                       style="-fx-font-size: 38px; -fx-text-fill: #c9a98a;" />
                <Label text="PLANETMEL"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #5c4033; -fx-font-family: 'Georgia';" />
                <Label text="SKIN CO."
                       style="-fx-font-size: 11px; -fx-text-fill: #b89c8a; -fx-font-family: 'Georgia';" />
                <Label text=" " style="-fx-font-size: 4px;" />
                <Label fx:id="lblSubtitle"
                       text="Sign in to your account"
                       style="-fx-font-size: 13px; -fx-text-fill: #a08878; -fx-font-family: 'Georgia'; -fx-font-style: italic;"
                       wrapText="true" />
            </VBox>

            <Separator maxWidth="420.0" style="-fx-background-color: #e8d5c4;" />

            <VBox maxWidth="420.0" spacing="12.0"
                  style="-fx-background-color: #fffaf7; -fx-background-radius: 12px; -fx-border-color: #e8d5c4; -fx-border-radius: 12px; -fx-border-width: 1px;">
                <padding>
                    <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                </padding>

                <GridPane hgap="12.0" vgap="12.0">
                    <columnConstraints>
                        <ColumnConstraints minWidth="100.0" prefWidth="120.0" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                    </rowConstraints>

                    <Label text="Username"
                           style="-fx-text-fill: #7a5c4f; -fx-font-family: 'Georgia'; -fx-font-size: 13px;"
                           GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <TextField fx:id="txtUser"
                               promptText="Enter username"
                               style="-fx-background-color: #fdf6f0; -fx-border-color: #ddc9b8; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-font-size: 13px;"
                               GridPane.columnIndex="1" GridPane.rowIndex="0" />

                    <Label text="Password"
                           style="-fx-text-fill: #7a5c4f; -fx-font-family: 'Georgia'; -fx-font-size: 13px;"
                           GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <PasswordField fx:id="pwd"
                                   promptText="Enter your password"
                                   style="-fx-background-color: #fdf6f0; -fx-border-color: #ddc9b8; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-font-size: 13px;"
                                   GridPane.columnIndex="1" GridPane.rowIndex="1" />

                    <Label fx:id="lblStatus"
                           style="-fx-text-fill: #b00020; -fx-font-size: 12px;"
                           text="" wrapText="true"
                           GridPane.columnIndex="1" GridPane.rowIndex="3" />
                </GridPane>

                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Button fx:id="btnLogin" defaultButton="true" onAction="#handleLogin" text="Sign In"
                            style="-fx-background-color: #c9a98a; -fx-text-fill: white; -fx-font-family: 'Georgia'; -fx-font-size: 13px; -fx-background-radius: 6px; -fx-padding: 8 20 8 20;" />
                    <Button fx:id="btnExit" cancelButton="true" onAction="#handleExit" text="Exit"
                            style="-fx-background-color: transparent; -fx-text-fill: #a08878; -fx-font-family: 'Georgia'; -fx-font-size: 13px; -fx-border-color: #ddc9b8; -fx-border-radius: 6px; -fx-padding: 8 20 8 20;" />
                </HBox>
            </VBox>

            <Label text="© 2025 PlanetMel Skin Co."
                   style="-fx-font-size: 11px; -fx-text-fill: #c4a898; -fx-font-family: 'Georgia'; -fx-font-style: italic;" />
        </VBox>
    </center>
</BorderPane>
