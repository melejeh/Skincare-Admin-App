<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="16.0"
      style="-fx-background-color: #fdf6f0; -fx-padding: 24;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="PlanetMel.controller.AddNewProductController">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="✦" style="-fx-font-size: 18px; -fx-text-fill: #c9a98a;" />
        <Label text="Add New Product"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #5c4033; -fx-font-family: 'Georgia';" />
    </HBox>

    <Separator style="-fx-background-color: #e8d5c4;" />

    <!-- Form card -->
    <VBox spacing="12.0" maxWidth="480.0"
          style="-fx-background-color: #fffaf7; -fx-background-radius: 12px; -fx-border-color: #e8d5c4; -fx-border-radius: 12px; -fx-border-width: 1px;">
        <padding>
            <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
        </padding>

        <GridPane hgap="12.0" vgap="12.0">
            <columnConstraints>
                <ColumnConstraints minWidth="110.0" prefWidth="120.0" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints /><RowConstraints /><RowConstraints />
                <RowConstraints /><RowConstraints />
            </rowConstraints>

            <Label text="Name" style="-fx-text-fill: #7a5c4f; -fx-font-family: 'Georgia'; -fx-font-size: 13px;"
                   GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="nameField" promptText="e.g. HydraClean Gel"
                       style="-fx-background-color: #fdf6f0; -fx-border-color: #ddc9b8; -fx-border-radius: 6px; -fx-background-radius: 6px;"
                       GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label text="Category" style="-fx-text-fill: #7a5c4f; -fx-font-family: 'Georgia'; -fx-font-size: 13px;"
                   GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="categoryField" promptText="e.g. Cleanser"
                       style="-fx-background-color: #fdf6f0; -fx-border-color: #ddc9b8; -fx-border-radius: 6px; -fx-background-radius: 6px;"
                       GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label text="Price ($)" style="-fx-text-fill: #7a5c4f; -fx-font-family: 'Georgia'; -fx-font-size: 13px;"
                   GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <TextField fx:id="priceField" promptText="e.g. 24.99"
                       style="-fx-background-color: #fdf6f0; -fx-border-color: #ddc9b8; -fx-border-radius: 6px; -fx-background-radius: 6px;"
                       GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <Label text="Image URL" style="-fx-text-fill: #7a5c4f; -fx-font-family: 'Georgia'; -fx-font-size: 13px;"
                   GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <TextField fx:id="imageUrlField" promptText="e.g. images/serum.jpg"
                       style="-fx-background-color: #fdf6f0; -fx-border-color: #ddc9b8; -fx-border-radius: 6px; -fx-background-radius: 6px;"
                       GridPane.columnIndex="1" GridPane.rowIndex="3" />

            <Label text="Description" style="-fx-text-fill: #7a5c4f; -fx-font-family: 'Georgia'; -fx-font-size: 13px;"
                   GridPane.columnIndex="0" GridPane.rowIndex="4" />
            <TextArea fx:id="descriptionArea" promptText="Short product description..."
                      prefHeight="80.0"
                      style="-fx-background-color: #fdf6f0; -fx-border-color: #ddc9b8; -fx-border-radius: 6px; -fx-background-radius: 6px;"
                      GridPane.columnIndex="1" GridPane.rowIndex="4" />
        </GridPane>

        <HBox spacing="10.0">
            <Button text="Add Product" onAction="#onAddProduct"
                    style="-fx-background-color: #c9a98a; -fx-text-fill: white; -fx-font-family: 'Georgia'; -fx-background-radius: 6px; -fx-padding: 8 20 8 20;" />
            <Button text="Clear" onAction="#onClear"
                    style="-fx-background-color: transparent; -fx-text-fill: #a08878; -fx-font-family: 'Georgia'; -fx-border-color: #ddc9b8; -fx-border-radius: 6px; -fx-padding: 8 20 8 20;" />
        </HBox>

        <Label fx:id="statusLabel" style="-fx-text-fill: #5c4033; -fx-font-family: 'Georgia'; -fx-font-size: 12px;" />
    </VBox>

    <Label text="© 2025 PlanetMel Skin Co."
           style="-fx-font-size: 11px; -fx-text-fill: #c4a898; -fx-font-family: 'Georgia'; -fx-font-style: italic;" />

</VBox>
