<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane
        style="-fx-background-color: #fdf6f0;"
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="PlanetMel.controller.InitializeISkyController">

    <center>
        <VBox alignment="TOP_CENTER" spacing="16.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>

            <!-- Brand Header -->
            <VBox alignment="CENTER" spacing="4.0">
                <Label text="✦" style="-fx-font-size: 28px; -fx-text-fill: #c9a98a;" />
                <Label text="PLANETMEL"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #5c4033; -fx-font-family: 'Georgia';" />
                <Label text="SKIN CO."
                       style="-fx-font-size: 10px; -fx-text-fill: #b89c8a; -fx-font-family: 'Georgia';" />
            </VBox>

            <!-- Title -->
            <VBox maxWidth="720.0" spacing="6.0" alignment="CENTER">
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #5c4033; -fx-font-family: 'Georgia';"
                       text="First-time Setup" />
                <Label fx:id="lblSubtitle" textFill="#b00020" wrapText="true" alignment="CENTER"
                       text="This system is not initialized. Create the Master account to continue." />
                <Label style="-fx-text-fill: #a08878; -fx-font-style: italic; -fx-font-family: 'Georgia'; -fx-font-size: 12px;"
                       text="This setup screen will be disabled after initialization." wrapText="true" />
            </VBox>

            <Separator maxWidth="720.0" style="-fx-background-color: #e8d5c4;" />

            <!-- Main content -->
            <GridPane hgap="18.0" maxWidth="720.0" vgap="10.0">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="420.0" prefWidth="480.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="240.0" prefWidth="240.0" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints />
                </rowConstraints>

                <!-- Left: form -->
                <VBox spacing="10.0" GridPane.columnIndex="0" GridPane.rowIndex="0"
                      style="-fx-background-color: #fffaf7; -fx-background-radius: 12px; -fx-border-color: #e8d5c4; -fx-border-radius: 12px; -fx-border-width: 1px;">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>

                    <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #5c4033; -fx-font-family: 'Georgia';"
                           text="Master Account" />

                    <GridPane hgap="10.0" vgap="10.0">
                        <columnConstraints>
                            <ColumnConstraints minWidth="150.0" prefWidth="160.0" />
                            <ColumnConstraints hgrow="ALWAYS" />
                        </columnConstraints>
                        <rowConstraints>
                            <RowConstraints /><RowConstraints /><RowConstraints />
                            <RowConstraints /><RowConstraints /><RowConstraints /><RowConstraints />
                        </rowConstraints>

                        <Label text="Master username"
                               style="-fx-text-fill: #7a5c4f; -fx-font-family: 'Georgia'; -fx-font-size: 13px;"
                               GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField fx:id="txtMasterUser" promptText="e.g., planetmel-master"
                                   style="-fx-background-color: #fdf6f0; -fx-border-color: #ddc9b8; -fx-border-radius: 6px; -fx-background-radius: 6px;"
                                   GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <Label style="-fx-text-fill: #a08878; -fx-font-size: 11px; -fx-font-style: italic;"
                               text="Use a unique ID (no default credentials)."
                               GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label text="Contact email (optional)"
                               style="-fx-text-fill: #7a5c4f; -fx-font-family: 'Georgia'; -fx-font-size: 13px;"
                               GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <TextField fx:id="txtMasterEmail" promptText="e.g., name@planetmel.com"
                                   style="-fx-background-color: #fdf6f0; -fx-border-color: #ddc9b8; -fx-border-radius: 6px; -fx-background-radius: 6px;"
                                   GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <Label style="-fx-text-fill: #a08878; -fx-font-size: 11px; -fx-font-style: italic;"
                               text="Used for notifications in later tasks."
                               GridPane.columnIndex="1" GridPane.rowIndex="3" />

                        <Label text="New password"
                               style="-fx-text-fill: #7a5c4f; -fx-font-family: 'Georgia'; -fx-font-size: 13px;"
                               GridPane.columnIndex="0" GridPane.rowIndex="4" />
                        <GridPane hgap="8.0" GridPane.columnIndex="1" GridPane.rowIndex="4">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" />
                                <ColumnConstraints minWidth="80.0" />
                            </columnConstraints>
                            <rowConstraints><RowConstraints /></rowConstraints>
                            <PasswordField fx:id="pwd1" promptText="Enter a strong password"
                                           style="-fx-background-color: #fdf6f0; -fx-border-color: #ddc9b8; -fx-border-radius: 6px; -fx-background-radius: 6px;"
                                           GridPane.columnIndex="0" GridPane.rowIndex="0" />
                            <TextField fx:id="txtPwd1Visible" managed="false" visible="false"
                                       promptText="Enter a strong password"
                                       style="-fx-background-color: #fdf6f0; -fx-border-color: #ddc9b8; -fx-border-radius: 6px; -fx-background-radius: 6px;"
                                       GridPane.columnIndex="0" GridPane.rowIndex="0" />
                            <CheckBox fx:id="chkShowPwd1" text="Show"
                                      style="-fx-text-fill: #a08878; -fx-font-size: 12px;"
                                      GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        </GridPane>

                        <Label text="Confirm password"
                               style="-fx-text-fill: #7a5c4f; -fx-font-family: 'Georgia'; -fx-font-size: 13px;"
                               GridPane.columnIndex="0" GridPane.rowIndex="5" />
                        <GridPane hgap="8.0" GridPane.columnIndex="1" GridPane.rowIndex="5">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" />
                                <ColumnConstraints minWidth="80.0" />
                            </columnConstraints>
                            <rowConstraints><RowConstraints /></rowConstraints>
                            <PasswordField fx:id="pwd2" promptText="Re-enter password"
                                           style="-fx-background-color: #fdf6f0; -fx-border-color: #ddc9b8; -fx-border-radius: 6px; -fx-background-radius: 6px;"
                                           GridPane.columnIndex="0" GridPane.rowIndex="0" />
                            <TextField fx:id="txtPwd2Visible" managed="false" visible="false"
                                       promptText="Re-enter password"
                                       style="-fx-background-color: #fdf6f0; -fx-border-color: #ddc9b8; -fx-border-radius: 6px; -fx-background-radius: 6px;"
                                       GridPane.columnIndex="0" GridPane.rowIndex="0" />
                            <CheckBox fx:id="chkShowPwd2" text="Show"
                                      style="-fx-text-fill: #a08878; -fx-font-size: 12px;"
                                      GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        </GridPane>

                        <Label fx:id="lblStatus" style="-fx-text-fill: #b00020; -fx-font-size: 12px;"
                               text="" wrapText="true"
                               GridPane.columnIndex="1" GridPane.rowIndex="6" />
                    </GridPane>
                </VBox>

                <!-- Right: password rules -->
                <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="0"
                      style="-fx-background-color: #fffaf7; -fx-background-radius: 12px; -fx-border-color: #e8d5c4; -fx-border-radius: 12px; -fx-border-width: 1px;">
                    <padding>
                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                    </padding>
                    <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #5c4033; -fx-font-family: 'Georgia';"
                           text="Password Rules" />
                    <Label fx:id="lblRuleLen" text="• At least 12 characters"
                           style="-fx-text-fill: #b00020;" wrapText="true" />
                    <Label fx:id="lblRuleCommon" text="• Not a common/weak password"
                           style="-fx-text-fill: #b00020;" wrapText="true" />
                    <Label fx:id="lblRuleUser" text="• Not the same as the username"
                           style="-fx-text-fill: #b00020;" wrapText="true" />
                    <Label fx:id="lblRuleChars" text="• Spaces and special characters allowed"
                           style="-fx-text-fill: #1b5e20;" wrapText="true" />
                    <Separator style="-fx-background-color: #e8d5c4;" />
                    <Label style="-fx-text-fill: #a08878; -fx-font-style: italic; -fx-font-size: 12px; -fx-font-family: 'Georgia';"
                           text="Tip: Use a passphrase (e.g., 4+ random words)." wrapText="true" />
                </VBox>
            </GridPane>

            <!-- Buttons -->
            <HBox alignment="CENTER_LEFT" maxWidth="720.0" spacing="10.0">
                <Button fx:id="btnCreateMaster" defaultButton="true" disable="true"
                        onAction="#handleCreateMaster" text="Create Master Account"
                        style="-fx-background-color: #c9a98a; -fx-text-fill: white; -fx-font-family: 'Georgia'; -fx-font-size: 13px; -fx-background-radius: 6px; -fx-padding: 8 20 8 20;" />
                <Button fx:id="btnExit" cancelButton="true" onAction="#handleExit" text="Exit"
                        style="-fx-background-color: transparent; -fx-text-fill: #a08878; -fx-font-family: 'Georgia'; -fx-font-size: 13px; -fx-border-color: #ddc9b8; -fx-border-radius: 6px; -fx-padding: 8 20 8 20;" />
            </HBox>

            <Label text="© 2025 PlanetMel Skin Co."
                   style="-fx-font-size: 11px; -fx-text-fill: #c4a898; -fx-font-family: 'Georgia'; -fx-font-style: italic;" />

        </VBox>
    </center>
</BorderPane>
