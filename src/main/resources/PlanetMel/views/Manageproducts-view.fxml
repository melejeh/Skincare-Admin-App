<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="16.0"
      style="-fx-background-color: #fdf6f0; -fx-padding: 24;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="PlanetMel.controller.ManageProductController">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="✦" style="-fx-font-size: 18px; -fx-text-fill: #c9a98a;" />
        <Label text="Manage Products"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #5c4033; -fx-font-family: 'Georgia';" />
    </HBox>

    <Separator style="-fx-background-color: #e8d5c4;" />

    <!-- Table -->
    <TableView fx:id="productTable" prefHeight="380.0"
               style="-fx-background-color: #fffaf7; -fx-border-color: #e8d5c4; -fx-border-radius: 8px;">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
            <TableColumn fx:id="colName" text="Name" prefWidth="160"/>
            <TableColumn fx:id="colCategory" text="Category" prefWidth="120"/>
            <TableColumn fx:id="colPrice" text="Price ($)" prefWidth="100"/>
            <TableColumn fx:id="colDescription" text="Description" prefWidth="250"/>
        </columns>
    </TableView>

    <!-- Buttons -->
    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <Button text="Edit Selected" onAction="#onEditProduct"
                style="-fx-background-color: #5c4033; -fx-text-fill: white; -fx-font-family: 'Georgia'; -fx-background-radius: 6px; -fx-padding: 8 16 8 16;" />
        <Button text="Delete Selected" onAction="#onDeleteProduct"
                style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-family: 'Georgia'; -fx-background-radius: 6px; -fx-padding: 8 16 8 16;" />
        <Button text="Refresh" onAction="#onRefresh"
                style="-fx-background-color: #c9a98a; -fx-text-fill: white; -fx-font-family: 'Georgia'; -fx-background-radius: 6px; -fx-padding: 8 16 8 16;" />
    </HBox>

    <Label fx:id="statusLabel" style="-fx-text-fill: #5c4033; -fx-font-family: 'Georgia'; -fx-font-size: 12px;" />

    <Label text="© 2025 PlanetMel Skin Co."
           style="-fx-font-size: 11px; -fx-text-fill: #c4a898; -fx-font-family: 'Georgia'; -fx-font-style: italic;" />

</VBox>
